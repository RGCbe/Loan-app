# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (REQUIRED - server will not start without this)
JWT_SECRET="change-this-to-a-strong-random-secret"

# Database path (relative to project root)
DB_PATH="loans.db"

# Admin account (auto-created on first run with premium access)
ADMIN_USERNAME="your-username@metrix"
ADMIN_PASSWORD="your-strong-password"
